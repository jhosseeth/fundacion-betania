---
// Donaciones.astro — Sección 08: Conversión — datos bancarios + contexto de impacto
import SectionTitle from '../ui/SectionTitle.astro';
import BankCard from '../ui/BankCard.astro';
import { SITE } from '../../data/site.ts';

const impactoPills = [
  { emoji: '🍽️', texto: 'Alimenta a 1 niño por una semana' },
  { emoji: '📚', texto: 'Financia un mes de refuerzo escolar' },
  { emoji: '🏠', texto: 'Sostiene el comedor por un día' },
];

const impactoItems = [
  { texto: 'Alimenta +800 raciones al mes' },
  { texto: 'Equipa el refuerzo escolar de 40 niños' },
  { texto: 'Sostiene los programas de jóvenes' },
  { texto: 'Mantiene el espacio abierto para 200+ familias' },
];
---

<section class="donaciones" id="donaciones" aria-label="Dona y transforma una vida">
  <div class="container">
    <!-- Encabezado -->
    <SectionTitle
      eyebrow="Tu aporte importa"
      title="Dona y transforma una vida"
      subtitle="Cada peso cuenta. Tu donación llega directamente a las familias de nuestra comunidad."
    />

    <!-- Selector visual de impacto (no funcional — solo inspiración) -->
    <div class="donaciones__pills" aria-label="Ejemplos de impacto de tu donación" role="list">
      {impactoPills.map((pill) => (
        <div class="impact-pill" role="listitem">
          <span class="impact-pill__emoji" aria-hidden="true">{pill.emoji}</span>
          <span class="impact-pill__texto">{pill.texto}</span>
        </div>
      ))}
    </div>

    <!-- Layout de dos columnas: BankCard + Impacto -->
    <div class="donaciones__layout">
      <!-- Izquierda: datos bancarios -->
      <div class="donaciones__bank">
        <h3 class="donaciones__col-title">Datos bancarios</h3>
        <BankCard />
      </div>

      <!-- Derecha: impacto -->
      <div class="donaciones__impact">
        <h3 class="donaciones__col-title">¿Qué hace tu donación?</h3>

        <ul class="impacto-lista" aria-label="Impacto de tu donación">
          {impactoItems.map((item) => (
            <li class="impacto-lista__item">
              <span class="impacto-lista__check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              <span>{item.texto}</span>
            </li>
          ))}
        </ul>

        <!-- Nota de confianza -->
        <p class="donaciones__nota-confianza">
          <span aria-hidden="true">🔒</span>
          100% de tu donación llega a los programas
        </p>

        <!-- QR placeholder -->
        <div class="donaciones__qr-wrap">
          <div class="donaciones__qr-box" role="img" aria-label="Código QR para donar — próximamente">
            <div class="qr-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="1.5"
                   stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true" opacity="0.45">
                <rect x="3" y="3" width="7" height="7" />
                <rect x="14" y="3" width="7" height="7" />
                <rect x="3" y="14" width="7" height="7" />
                <rect x="17" y="17" width="4" height="4" />
                <line x1="14" y1="14" x2="14" y2="14" />
              </svg>
              <p class="qr-placeholder__texto">Escanea para donar</p>
              <p class="qr-placeholder__sub">Código QR próximamente</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Nota legal -->
    <p class="donaciones__legal">
      {SITE.bank.holder} — NIT {SITE.bank.nit} — Entidad sin ánimo de lucro
    </p>
  </div>
</section>

<style>
  /* ---- Sección base ---- */
  .donaciones {
    background-color: var(--color-cream-dark);
    padding-block: var(--space-16);
  }

  @media (min-width: 1024px) {
    .donaciones {
      padding-block: var(--space-20);
    }
  }

  /* ---- Pills de impacto ---- */
  .donaciones__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-10);
  }

  .impact-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-white);
    border: 2px solid rgba(63, 78, 181, 0.15);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-5);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text);
    box-shadow: var(--shadow-sm);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
    min-height: 44px;
  }

  .impact-pill:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 768px) {
    .impact-pill {
      font-size: var(--text-base);
      padding: var(--space-3) var(--space-6);
    }
  }

  .impact-pill__emoji {
    font-size: 1.25rem;
    line-height: 1;
  }

  /* ---- Layout dos columnas ---- */
  .donaciones__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    margin-top: var(--space-12);
    align-items: start;
  }

  @media (min-width: 768px) {
    .donaciones__layout {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }
  }

  /* ---- Columnas ---- */
  .donaciones__bank,
  .donaciones__impact {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .donaciones__col-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-extrabold);
    color: var(--color-text);
    max-width: none;
  }

  /* ---- Lista de impacto ---- */
  .impacto-lista {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .impacto-lista__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-base);
    line-height: 1.55;
    color: var(--color-text);
  }

  .impacto-lista__check {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    background: rgba(139, 199, 173, 0.25);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #2d8a6a;
    margin-top: 1px;
  }

  /* ---- Nota de confianza ---- */
  .donaciones__nota-confianza {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    background: rgba(139, 199, 173, 0.15);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-5);
    max-width: none;
  }

  /* ---- QR placeholder ---- */
  .donaciones__qr-wrap {
    display: flex;
  }

  .donaciones__qr-box {
    border: 2px dashed rgba(63, 78, 181, 0.25);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 160px;
    min-height: 160px;
    background: var(--color-white);
  }

  .qr-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    text-align: center;
  }

  .qr-placeholder__texto {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text);
    max-width: none;
  }

  .qr-placeholder__sub {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    max-width: none;
  }

  /* ---- Nota legal ---- */
  .donaciones__legal {
    margin-top: var(--space-12);
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    opacity: 0.7;
    max-width: none;
  }
</style>
