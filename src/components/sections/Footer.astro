---
// Footer.astro — (12) Pie de página
// Fondo --color-primary | Texto blanco/semitransparente
// Incluye aviso Habeas Data (Ley 1581 de 2012, Colombia)

import { SITE } from '../../data/site';

const navLinks = [
  { label: 'Quiénes Somos',   href: '#quienes-somos' },
  { label: 'Programas',       href: '#programas' },
  { label: 'Cómo Ayudar',     href: '#como-ayudar' },
  { label: 'Donaciones',      href: '#donaciones' },
  { label: 'Galería',         href: '#galeria' },
  { label: 'Contacto',        href: '#contacto' },
];
---

<footer class="footer" role="contentinfo" aria-label="Pie de página de Fundación Betania">

  <!-- ===== Cuerpo principal ===== -->
  <div class="footer__main">
    <div class="container footer__grid">

      <!-- ---- Columna 1: Marca ---- -->
      <div class="footer__brand">
        <a href="#inicio" class="footer__logo-link" aria-label="Volver al inicio — Fundación Betania">
          <img
            src="/logo-footer.jpg"
            alt="Fundación Betania"
            width="80"
            height="80"
            loading="lazy"
            class="footer__logo"
          />
        </a>

        <p class="footer__tagline">{SITE.tagline}</p>

        <!-- Redes sociales -->
        <div class="footer__social" aria-label="Redes sociales">
          <a
            href={SITE.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label="Fundación Betania en Instagram"
          >
            <!-- Ícono Instagram -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
            <span class="footer__social-label">Instagram</span>
          </a>
        </div>
      </div>

      <!-- ---- Columna 2: Navegación ---- -->
      <nav class="footer__nav" aria-label="Navegación del pie de página">
        <h3 class="footer__col-title">Explorar</h3>
        <ul class="footer__nav-list" role="list">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__nav-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- ---- Columna 3: Contacto ---- -->
      <div class="footer__contact">
        <h3 class="footer__col-title">Contacto</h3>
        <ul class="footer__contact-list" role="list">
          <!-- Email -->
          <li class="footer__contact-item">
            <svg
              class="footer__contact-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="4" width="20" height="16" rx="3" />
              <path d="M2 7l10 7 10-7" />
            </svg>
            <a
              href={`mailto:${SITE.email}`}
              class="footer__contact-link"
              aria-label={`Enviar correo a ${SITE.email}`}
            >
              {SITE.email}
            </a>
          </li>

          <!-- WhatsApp -->
          <li class="footer__contact-item">
            <svg
              class="footer__contact-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M20.52 3.48A11.93 11.93 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.11.55 4.17 1.6 5.99L0 24l6.22-1.58A11.96 11.96 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.48-8.52zM12 22c-1.85 0-3.66-.5-5.22-1.44l-.38-.22-3.93 1 1.02-3.82-.24-.39A9.98 9.98 0 0 1 2 12C2 6.48 6.48 2 12 2s10 4.48 10 10-4.48 10-10 10zm5.47-7.37c-.28-.14-1.64-.81-1.9-.9-.25-.09-.44-.14-.62.14-.18.28-.71.9-.87 1.08-.16.18-.32.2-.6.07-.28-.14-1.18-.44-2.24-1.39-.83-.74-1.39-1.65-1.55-1.93-.16-.28-.02-.43.12-.57.13-.12.28-.32.42-.48.14-.16.19-.28.28-.46.09-.18.05-.34-.02-.48-.07-.14-.62-1.5-.85-2.05-.22-.54-.45-.46-.62-.47h-.52c-.18 0-.46.07-.7.34-.24.27-.92.9-.92 2.19s.94 2.54 1.07 2.72c.14.18 1.85 2.82 4.48 3.95.63.27 1.12.43 1.5.55.63.2 1.2.17 1.65.1.5-.07 1.64-.67 1.87-1.32.23-.65.23-1.2.16-1.32-.07-.12-.25-.18-.53-.32z"/>
            </svg>
            <a
              href={SITE.whatsapp.link}
              target="_blank"
              rel="noopener noreferrer"
              class="footer__contact-link"
              aria-label={`Contactar por WhatsApp al ${SITE.phone}`}
            >
              {SITE.phone}
            </a>
          </li>

          <!-- Horarios -->
          <li class="footer__contact-item">
            <svg
              class="footer__contact-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            <span class="footer__contact-text">{SITE.address.hours}</span>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- ===== Divisor ===== -->
  <div class="footer__divider" aria-hidden="true"></div>

  <!-- ===== Pie inferior ===== -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copyright">
        &copy; 2025 Fundación Betania Integral Colombia &middot; NIT 902051724
      </p>
      <p class="footer__legal">
        <a href="#habeas-data" class="footer__legal-link">Política de privacidad — Habeas Data</a>
      </p>
    </div>
  </div>

  <!-- ===== Aviso Habeas Data ===== -->
  <div id="habeas-data" class="footer__habeas" aria-label="Aviso de tratamiento de datos personales">
    <div class="container">
      <p class="footer__habeas-text">
        <strong>Habeas Data — Ley 1581 de 2012:</strong>
        De conformidad con la Ley 1581 de 2012 y el Decreto 1377 de 2013, Fundación Betania Integral Colombia informa que los datos personales recopilados son utilizados exclusivamente para mantener contacto con donantes, voluntarios y beneficiarios, y para el envío de información sobre nuestros programas. Los datos no serán vendidos ni cedidos a terceros. Para ejercer sus derechos de acceso, corrección o supresión, escríbanos a:
        <a href={`mailto:${SITE.email}`} class="footer__habeas-link">{SITE.email}</a>
      </p>
    </div>
  </div>

</footer>

<style>
  /* ============ Base del footer ============ */
  .footer {
    background-color: var(--color-primary);
    color: rgba(255, 255, 255, 0.85);
  }

  /* ============ Cuerpo principal ============ */
  .footer__main {
    padding-block: var(--space-16) var(--space-12);
  }

  @media (min-width: 1024px) {
    .footer__main {
      padding-block: var(--space-20) var(--space-16);
    }
  }

  /* ---- Grid 1 col mobile → 3 col desktop ---- */
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12) var(--space-10);
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1.5fr;
      gap: var(--space-12);
      align-items: start;
    }
  }

  /* ============ Columna 1: Marca ============ */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .footer__logo-link {
    display: inline-block;
    width: fit-content;
  }

  .footer__logo {
    height: 80px;
    width: 80px;
    object-fit: cover;
    display: block;
    border-radius: 16px;
  }

  .footer__tagline {
    font-size: var(--text-base);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.72);
    max-width: 34ch;
  }

  /* ---- Redes sociales ---- */
  .footer__social {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 44px;
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-full);
    background-color: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .footer__social-link:hover {
    background-color: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .footer__social-label {
    font-size: var(--text-sm);
  }

  /* ============ Columna 2: Navegación ============ */
  .footer__col-title {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__nav-link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color var(--transition-fast), padding-left var(--transition-fast);
  }

  .footer__nav-link:hover {
    color: #fff;
    padding-left: var(--space-2);
  }

  /* ============ Columna 3: Contacto ============ */
  .footer__contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .footer__contact-icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 2px;
  }

  .footer__contact-link,
  .footer__contact-text {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    line-height: 1.5;
    word-break: break-word;
    transition: color var(--transition-fast);
  }

  .footer__contact-link:hover {
    color: #fff;
  }

  /* ============ Divisor ============ */
  .footer__divider {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.12);
    margin-inline: var(--space-6);
  }

  @media (min-width: 768px) {
    .footer__divider {
      margin-inline: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .footer__divider {
      margin-inline: var(--space-12);
    }
  }

  /* ============ Pie inferior ============ */
  .footer__bottom {
    padding-block: var(--space-6);
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
      gap: var(--space-4);
      flex-wrap: wrap;
    }
  }

  .footer__copyright {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.55);
    max-width: unset;
  }

  .footer__legal {
    max-width: unset;
  }

  .footer__legal-link {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color var(--transition-fast);
  }

  .footer__legal-link:hover {
    color: var(--color-accent);
  }

  /* ============ Aviso Habeas Data ============ */
  .footer__habeas {
    background-color: rgba(0, 0, 0, 0.25);
    padding-block: var(--space-6);
  }

  .footer__habeas-text {
    font-size: var(--text-xs);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.45);
    max-width: 90ch;
  }

  .footer__habeas-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: underline;
    transition: color var(--transition-fast);
  }

  .footer__habeas-link:hover {
    color: var(--color-accent);
  }

  /* ============ Reduced motion ============ */
  @media (prefers-reduced-motion: reduce) {
    .footer__nav-link,
    .footer__social-link,
    .footer__contact-link,
    .footer__legal-link {
      transition: none;
    }
  }
</style>
