---
// NavBarSimple.astro — Barra de navegación simplificada para páginas interiores.
// Solo logo, sin nav links, sin botón Donar, sin barra de progreso de scroll.
// Fondo siempre sólido (no transparente → sólido). Logo enlaza a / (home).
---

<header class="nav-simple" role="banner">
  <div class="nav-simple__inner container">
    <a href="/" class="nav-simple__logo-link" aria-label="Volver a la página principal — Fundación Betania">
      <img
        src="/logo-symbol.jpg"
        alt="Fundación Betania"
        height="52"
        width="52"
        loading="eager"
        class="nav-simple__logo-img"
      />
    </a>
  </div>
</header>

<style>
  .nav-simple {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--nav-height);
    background-color: var(--color-cream);
    box-shadow: var(--shadow-md);
  }

  .nav-simple__inner {
    display: flex;
    align-items: center;
    height: 100%;
  }

  .nav-simple__logo-img {
    height: 52px;
    width: 52px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
    transition: opacity var(--transition-fast);
  }

  .nav-simple__logo-link:hover .nav-simple__logo-img {
    opacity: 0.85;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-simple__logo-img {
      transition: none;
    }
  }
</style>
