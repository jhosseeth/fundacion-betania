---
import { SITE } from '../../data/site';
---

<!-- Botón WhatsApp flotante -->
<a
  href={SITE.whatsapp.link}
  class="fab fab-whatsapp"
  aria-label="Contáctanos por WhatsApp"
  target="_blank"
  rel="noopener noreferrer"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="28"
    height="28"
    viewBox="0 0 24 24"
    fill="white"
    aria-hidden="true"
  >
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<!-- Botón Volver arriba -->
<button
  class="fab fab-top"
  id="btn-top"
  aria-label="Volver al inicio de la página"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="22"
    height="22"
    viewBox="0 0 24 24"
    fill="none"
    stroke="white"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <polyline points="18 15 12 9 6 15"></polyline>
  </svg>
</button>

<script>
  const btnTop = document.getElementById('btn-top');

  function updateVisibility() {
    if (!btnTop) return;
    if (window.scrollY > 300) {
      btnTop.classList.add('is-visible');
    } else {
      btnTop.classList.remove('is-visible');
    }
  }

  btnTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  window.addEventListener('scroll', updateVisibility, { passive: true });
  updateVisibility();
</script>

<style>
  /* ---- Base FAB ---- */
  .fab {
    position: fixed;
    right: 24px;
    z-index: 900;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
    border: none;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .fab:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 3px;
  }

  /* ---- WhatsApp ---- */
  .fab-whatsapp {
    bottom: 24px;
    background: #25D366;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
  }

  .fab-whatsapp:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 28px rgba(37, 211, 102, 0.55);
    color: white;
  }

  /* Pulso sutil en WhatsApp */
  @media (prefers-reduced-motion: no-preference) {
    .fab-whatsapp {
      animation: pulse-wa 3s ease-in-out infinite;
    }

    @keyframes pulse-wa {
      0%, 100% { box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4); }
      50%       { box-shadow: 0 4px 28px rgba(37, 211, 102, 0.65); }
    }
  }

  /* ---- Volver arriba ---- */
  .fab-top {
    bottom: 88px; /* Encima del WhatsApp */
    background: var(--color-primary);
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px);
    transition: opacity var(--transition-base), transform var(--transition-base), box-shadow var(--transition-fast);
  }

  .fab-top.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .fab-top:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  /* Mobile: subir para no tapar content */
  @media (max-width: 767px) {
    .fab-whatsapp {
      bottom: 80px;
    }
    .fab-top {
      bottom: 144px;
    }
  }
</style>
