---
// ProgramCard.astro — Tarjeta de programa de la fundación
// Las fotos se sirven como assets estáticos desde /photos/

interface Props {
  titulo: string;
  descripcion: string;
  icon: string;
  foto: string;         // nombre de archivo, se busca en /photos/
  tag: string;
  proximamente?: boolean;
}

const {
  titulo,
  descripcion,
  icon,
  foto,
  tag,
  proximamente = false,
} = Astro.props;

// Las fotos se sirven desde public/photos/ como assets estáticos
const fotoUrl = `/photos/${foto}`;
---

<article class:list={['program-card', { 'program-card--soon': proximamente }]}>
  <!-- Imagen -->
  <div class="program-card__image-wrapper">
    <img
      src={fotoUrl}
      alt={titulo}
      class="program-card__image"
      loading="lazy"
      decoding="async"
      width="400"
      height="300"
    />
    {proximamente && (
      <div class="program-card__overlay" aria-hidden="true">
        <span class="program-card__soon-badge">Próximamente</span>
      </div>
    )}
    <!-- Tag chip sobre la imagen -->
    <span class="program-card__tag">{tag}</span>
  </div>

  <!-- Contenido -->
  <div class="program-card__body">
    <div class="program-card__icon" aria-hidden="true">{icon}</div>
    <h3 class="program-card__title">{titulo}</h3>
    <p class="program-card__description">{descripcion}</p>
  </div>
</article>

<style>
  .program-card {
    background-color: var(--color-cream-dark);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base);
  }

  .program-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  /* ---- Imagen ---- */
  .program-card__image-wrapper {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .program-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .program-card:hover .program-card__image {
    transform: scale(1.04);
  }

  /* ---- Overlay "Próximamente" ---- */
  .program-card__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(30, 30, 46, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .program-card__soon-badge {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white);
    background-color: var(--color-accent);
    color: var(--color-text);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
  }

  /* ---- Tag chip ---- */
  .program-card__tag {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    letter-spacing: 0.06em;
    color: var(--color-text);
    background-color: var(--color-support);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    line-height: 1.8;
  }

  /* Cuando "Próximamente", el tag usa el color accent */
  .program-card--soon .program-card__tag {
    background-color: var(--color-accent);
  }

  /* ---- Cuerpo ---- */
  .program-card__body {
    padding: var(--space-5) var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .program-card__icon {
    font-size: 2rem;
    line-height: 1;
  }

  .program-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-extrabold);
    line-height: 1.2;
    color: var(--color-text);
  }

  .program-card__description {
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: none;
  }

  @media (min-width: 768px) {
    .program-card__description {
      font-size: var(--text-base);
    }
  }
</style>
