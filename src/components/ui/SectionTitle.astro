---
// SectionTitle.astro — Encabezado de sección reutilizable
// Usado al inicio de cada sección del sitio

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  light?: boolean; // texto blanco para secciones oscuras
}

const {
  eyebrow,
  title,
  subtitle,
  align = 'center',
  light = false,
} = Astro.props;
---

<div class:list={['section-title', `section-title--${align}`, { 'section-title--light': light }]}>
  {eyebrow && (
    <p class="section-title__eyebrow">{eyebrow}</p>
  )}
  <h2 class="section-title__heading">{title}</h2>
  {subtitle && (
    <p class="section-title__subtitle">{subtitle}</p>
  )}
</div>

<style>
  .section-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    /* En mobile siempre centrado */
    text-align: center;
    align-items: center;
  }

  /* Desktop: respeta el prop align */
  @media (min-width: 768px) {
    .section-title--left {
      text-align: left;
      align-items: flex-start;
    }

    .section-title--center {
      text-align: center;
      align-items: center;
    }
  }

  /* ---- Eyebrow ---- */
  .section-title__eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-support);
    max-width: none;
  }

  .section-title--light .section-title__eyebrow {
    color: var(--color-accent);
  }

  /* ---- Heading ---- */
  .section-title__heading {
    font-family: var(--font-display);
    font-weight: var(--font-extrabold);
    /* Fluid typography: mínimo 1.75rem → máximo 2.75rem */
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.15;
    color: var(--color-text);
  }

  .section-title--light .section-title__heading {
    color: var(--color-white);
  }

  /* ---- Subtitle ---- */
  .section-title__subtitle {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 60ch;
    opacity: 0.9;
  }

  @media (min-width: 768px) {
    .section-title__subtitle {
      font-size: var(--text-lg);
    }
  }

  .section-title--light .section-title__subtitle {
    color: rgba(255, 255, 255, 0.8);
    opacity: 1;
  }
</style>
